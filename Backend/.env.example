DJANGO_SECRET_KEY=neighborfridge-local-dev-secret-key-change-me-12345
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_TIME_ZONE=America/Los_Angeles
DJANGO_COOKIE_SECURE=False
DJANGO_COOKIE_SAMESITE=Lax

# Ollama (local LLM for item enrichment — optional, used as Tier 3 fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma2

# Receipt OCR Provider: "auto", "veryfi", or "local"
RECEIPT_PROCESSING_PROVIDER=auto

# Veryfi OCR (optional — only needed if using Veryfi provider)
VERYFI_CLIENT_ID=
VERYFI_CLIENT_SECRET=
VERYFI_USERNAME=
VERYFI_API_KEY=

# Email
# Dev default: keep console backend so teammates are not blocked by SMTP setup.
# For real email, switch EMAIL_BACKEND to django.core.mail.backends.smtp.EmailBackend
# and use an app password, not your normal Gmail password.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NeighborFridge <noreply@neighborfridge.com>
