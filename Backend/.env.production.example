DJANGO_SECRET_KEY=replace-me-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_TIME_ZONE=America/Los_Angeles
DJANGO_COOKIE_SECURE=True
DJANGO_COOKIE_SAMESITE=Lax
DJANGO_COOKIE_DOMAIN=
DJANGO_SQLITE_PATH=/srv/neighborfridge/shared/db.sqlite3
DJANGO_MEDIA_ROOT=/srv/neighborfridge/shared/media

# Ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2

# Receipt OCR
RECEIPT_PROCESSING_PROVIDER=local

# Veryfi OCR (optional)
VERYFI_CLIENT_ID=
VERYFI_CLIENT_SECRET=
VERYFI_USERNAME=
VERYFI_API_KEY=

# OpenStreetMap / Nominatim
NOMINATIM_EMAIL=
NOMINATIM_USER_AGENT=NeighborFridge/1.0 (production deployment)

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NeighborFridge <noreply@neighborfridge.com>
